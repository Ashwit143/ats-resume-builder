{
  "version": 2,
  "builds": [
    { "src": "api/*.js",   "use": "@vercel/node"   },
    { "src": "public/**",  "use": "@vercel/static"  }
  ],
  "routes": [
    { "src": "/api/(.*)",  "dest": "/api/$1" },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf))",
      "dest": "/public/$1"
    },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ],
  "functions": {
    "api/analyze.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
